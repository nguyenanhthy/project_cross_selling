   "source": [
    "# Gold Layer: Cross-Selling Outputs (Basket + Edge List)\n",
    "# Infrastructure: PySpark 3.3.0 + Delta Lake 2.1.0\n",
    "\n",
    "import pyspark\n",
    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql import functions as F\n",
    "from delta import configure_spark_with_delta_pip\n",
    "\n",
    "# Paths\n",
    "SILVER_PATH = \"/home/jovyan/work/delta_lake/silver/silver_cleaned_data\"\n",
    "GOLD_BASKET_PATH = \"/home/jovyan/work/delta_lake/gold/gold_basket\"\n",
    "GOLD_EDGE_LIST_PATH = \"/home/jovyan/work/delta_lake/gold/gold_edge_list\"\n",
    "\n",
    "# Initialize SparkSession with Delta Lake support\n",
    "builder = (\n",
    "    SparkSession.builder\n",
    "    .appName(\"gold-layer-cross-selling\")\n",
    "    .config(\"spark.sql.extensions\", \"io.delta.sql.DeltaSparkSessionExtension\")\n",
    "    .config(\"spark.sql.catalog.spark_catalog\", \"org.apache.spark.sql.delta.catalog.DeltaCatalog\")\n",
    ")\n",
    "spark = configure_spark_with_delta_pip(builder).getOrCreate()\n",
    "\n",
    "# Read Silver data\n",
    "print(\"Đang đọc dữ liệu Silver...\")\n",
    "silver_df = spark.read.format(\"delta\").load(SILVER_PATH)\n",
    "print(\"Silver sample:\")\n",
    "silver_df.show(5, truncate=False)\n",
    "\n",
    "# ----------------------\n",
    "# Table 1: gold_basket (Dành cho FP-Growth)\n",
    "# ----------------------\n",
    "print(\"\\nĐang xây dựng bảng gold_basket...\")\n",
    "gold_basket_df = (\n",
    "    silver_df\n",
    "    .groupBy(\"order_id\")\n",
    "    .agg(F.collect_set(\"product_category_name\").alias(\"items\"))\n",
    "    .filter(F.size(F.col(\"items\")) > 1)\n",
    ")\n",
    "\n",
    "print(\"gold_basket sample:\")\n",
    "gold_basket_df.show(5, truncate=False)\n",
    "\n",
    "# Write gold_basket as Delta table\n",
    "print(\"Đang lưu gold_basket xuống Delta Lake...\")\n",
    "gold_basket_df.write.format(\"delta\").mode(\"overwrite\").save(GOLD_BASKET_PATH)\n",
    "print(f\"Hoàn tất lưu gold_basket tại: {GOLD_BASKET_PATH}\")\n",
    "\n",
    "# ----------------------\n",
    "# Table 2: gold_edge_list (Dành cho Network Analysis)\n",
    "# ----------------------\n",
    "print(\"\\nĐang xây dựng bảng gold_edge_list...\")\n",
    "a = silver_df.alias(\"a\")\n",
    "b = silver_df.alias(\"b\")\n",
    "\n",
    "edge_pairs_df = (\n",
    "    a.join(b, on=\"order_id\")\n",
    "    .select(\n",
    "        F.col(\"a.product_category_name\").alias(\"source\"),\n",
    "        F.col(\"b.product_category_name\").alias(\"target\")\n",
    "    )\n",
    "    # Remove self-loops and duplicate undirected edges\n",
    "    .filter(F.col(\"source\") < F.col(\"target\"))\n",
    ")\n",
    "\n",
    "gold_edge_list_df = (\n",
    "    edge_pairs_df\n",
    "    .groupBy(\"source\", \"target\")\n",
    "    .agg(F.count(\"*\").alias(\"weight\"))\n",
    "    .orderBy(F.desc(\"weight\"))\n",
    ")\n",
    "\n",
    "print(\"gold_edge_list sample:\")\n",
    "gold_edge_list_df.show(10, truncate=False)\n",
    "\n",
    "# Write gold_edge_list as Delta table\n",
    "print(\"Đang lưu gold_edge_list xuống Delta Lake...\")\n",
    "gold_edge_list_df.write.format(\"delta\").mode(\"overwrite\").save(GOLD_EDGE_LIST_PATH)\n",
    "print(f\"Hoàn tất lưu gold_edge_list tại: {GOLD_EDGE_LIST_PATH}\")"
   ]
  },
